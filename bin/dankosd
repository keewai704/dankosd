#!/bin/sh
set -eu

resolve_config_path() {
    if [ "${DANKOSD_CONFIG_PATH:-}" ]; then
        printf '%s\n' "$DANKOSD_CONFIG_PATH"
        return 0
    fi

    user_path="${XDG_CONFIG_HOME:-$HOME/.config}/quickshell/ddc-osd"
    if [ -f "$user_path/shell.qml" ]; then
        printf '%s\n' "$user_path"
        return 0
    fi

    system_path="/usr/share/dankosd/qml"
    if [ -f "$system_path/shell.qml" ]; then
        printf '%s\n' "$system_path"
        return 0
    fi

    printf '%s\n' "$user_path"
}

config_path="$(resolve_config_path)"

usage() {
    echo "Usage: $0 serve|brightness <0-100>|contrast <0-100>|show <icon_name> <0-100>|<icon_name> <0-100>|status" >&2
    exit 2
}

[ "$#" -ge 1 ] || usage

case "$1" in
    serve)
        shift
        exec quickshell -p "$config_path" "$@"
        ;;
    brightness|contrast)
        command_name="$1"
        shift
        [ "$#" -eq 1 ] || usage
        exec quickshell ipc --any-display -p "$config_path" call osd "$command_name" "$1"
        ;;
    show)
        shift
        [ "$#" -eq 2 ] || usage
        exec quickshell ipc --any-display -p "$config_path" call osd level "$1" "$2"
        ;;
    status)
        shift
        [ "$#" -eq 0 ] || usage
        exec quickshell ipc --any-display -p "$config_path" call osd status
        ;;
    *)
        if [ "$#" -eq 2 ]; then
            exec quickshell ipc --any-display -p "$config_path" call osd level "$1" "$2"
        fi
        usage
        ;;
esac
